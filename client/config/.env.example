DACS_SERVER_URL=ws://127.0.0.1:8080/ws
DACS_CLIENT_ID=node-local
DACS_AGENT_TOKEN=change-me-agent-token
DACS_AGENT_VERSION=1.0
DACS_HEARTBEAT_SECONDS=10
DACS_INSECURE_TLS=false
DACS_WS_PING_INTERVAL_SECONDS=30
DACS_WS_PING_TIMEOUT_SECONDS=10
DACS_RECONNECT_BASE_SECONDS=2
DACS_RECONNECT_CAP_SECONDS=30
